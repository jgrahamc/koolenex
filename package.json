  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/multer": "2.1.0",
    "@types/node": "25.5.0",
    "@types/ws": "8.18.1",
